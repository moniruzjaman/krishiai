{
  "expo": {
    "name": "Krishi AI",
    "slug": "krishi-ai",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A8A1F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.krishiai.app",
      "buildNumber": "1",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "ফসলের রোগ শনাক্ত করতে ক্যামেরা ব্যবহার করা হয়।",
        "NSLocationWhenInUseUsageDescription": "আপনার এলাকার আবহাওয়া ও কৃষি তথ্য দেখাতে লোকেশন ব্যবহার করা হয়।",
        "NSMicrophoneUsageDescription": "ভয়েস সার্চ ও AI কথোপকথনের জন্য মাইক্রোফোন ব্যবহার করা হয়।"
      }
    },
    "android": {
      "package": "com.krishiai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A8A1F"
      },
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "fc268b55-a3b2-4c1b-8b7b-f5ee611e86fb"
      }
    }
  }
}